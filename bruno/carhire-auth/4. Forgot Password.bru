meta {
  name: 4. Forgot Password
  type: http
  seq: 4
}

post {
  url: {{supabaseUrl}}/auth/v1/recover
  body: json
  auth: none
}

headers {
  apikey: {{anonKey}}
  Content-Type: application/json
}

body:json {
  {
    "email": "{{testEmail}}"
  }
}

docs {
  Sends a password-reset email. Returns 200 even for unknown emails (no
  account enumeration). The emailed link lands on /auth/callback → /auth/reset-password.
}
